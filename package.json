{
  "name": "nxtvibes",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/api"
  ],
  "scripts": {
    "adb-reverse": "npm run --prefix apps/mobile adb-reverse",
    "dev:mobile": "cd apps/mobile && npm run android",
    "dev:api": "cd apps/api && mix phx.server",
    "dev:android": "npm run adb-reverse && cd apps/mobile && npm run android",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:android\"",
    "build:mobile": "cd apps/mobile && eas build",
    "install:mobile": "cd apps/mobile && npm install",
    "typecheck": "cd apps/mobile && npm run typecheck",
    "test": "cd apps/mobile && npm test"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
