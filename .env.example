# =============================================================================
# NxtVibes — Environment Variables Reference
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# =============================================================================

# ─── Supabase (Database + Auth) ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
SUPABASE_ANON_KEY=your_anon_key

# Direct PostgreSQL connection string (for Phoenix Ecto)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=nxtvibes-media
R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ─── AI / LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
HUGGINGFACE_API_KEY=your_huggingface_api_key  # For embeddings (bge-base-en-v1.5)
UNSPLASH_ACCESS_KEY=your_unsplash_key
TAVILY_API_KEY=your_tavily_key

# ─── Zilliz Vector DB (RAG) ───────────────────────────────────────────────────
ZILLIZ_ENDPOINT=https://your-cluster.api.gcp-us-west1.zillizcloud.com
ZILLIZ_API_KEY=your_zilliz_api_key

# ─── Cache / Rate Limiting ────────────────────────────────────────────────────
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_token

# ─── Error Monitoring ─────────────────────────────────────────────────────────
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ─── Phoenix / Elixir ─────────────────────────────────────────────────────────
PHX_HOST=api.nxtvibes.com        # Production hostname
SECRET_KEY_BASE=                  # Run: mix phx.gen.secret
PORT=4000

# ─── Deployment ───────────────────────────────────────────────────────────────
FLY_APP_NAME=nxtvibes-api
